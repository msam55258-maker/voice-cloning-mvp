# Voice Cloning MVP — Environment Variables
# Copy this file to .env and adjust values for your environment.
# The application uses sane defaults for local development; you only
# need to set variables here if you want to override those defaults.

# ── Storage directories ──────────────────────────────────────────
# Where uploaded voice samples are stored.
# VOICES_DIR=backend/voices

# Where generated audio files are written.
# OUTPUTS_DIR=backend/outputs

# ── Upload validation ────────────────────────────────────────────
# Maximum allowed voice-sample file size in megabytes.
# MAX_FILE_SIZE_MB=10

# Minimum audio duration (seconds) for an uploaded voice sample.
# MIN_AUDIO_DURATION_S=3

# ── Text limits ──────────────────────────────────────────────────
# Script text length bounds for the /generate endpoint.
# MIN_TEXT_CHARS=10
# MAX_TEXT_CHARS=500

# ── TTS model ────────────────────────────────────────────────────
# Coqui TTS model identifier downloaded on first run (~1.87 GB).
# TTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2

# Output audio language code (XTTS v2 supports en, es, fr, de, etc.)
# TTS_LANGUAGE=en
